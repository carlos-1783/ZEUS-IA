# Production Environment Variables for ZEUS-IA Frontend
# Copy this to .env.production and configure in Railway Dashboard

# Backend API (Vite inyecta en build). Recomendado MISMO ORIGEN (un servicio): dejar vacío → el cliente usa window.location + /api/v1.
# Solo rellena si el frontend y el API están en hosts distintos (ej. app.zeus-ia.com + api.zeus-ia.com).
# VITE_API_BASE_URL=/api/v1 también vale (se convierte a URL absoluta en el navegador).
#
# VITE_API_URL=https://tu-backend.up.railway.app
# VITE_API_BASE_URL=https://tu-backend.up.railway.app/api/v1
# REACT_APP_API_URL=https://tu-backend.up.railway.app/api/v1

# Frontend URL (will be provided by Railway after deployment)
# Update CORS_ORIGINS in backend after getting this URL
VITE_APP_URL=https://zeus-ia-frontend-production.up.railway.app

# WebSocket URL
VITE_WS_URL=wss://zeus-ia-production.up.railway.app

# Chat con agentes (LLM): alinear con GUNICORN_TIMEOUT del backend (p. ej. 300000 = 5 min)
VITE_AGENT_CHAT_TIMEOUT_MS=300000

# Application Settings
VITE_APP_NAME=ZEUS-IA
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_SENTRY=false

