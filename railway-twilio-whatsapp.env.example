# Copiar en Railway > Variables (solo Twilio/WhatsApp)
#
# Desactivar envío hasta tener sandbox o número de WhatsApp Business aprobado en Twilio:
# TWILIO_WHATSAPP_ENABLED=false
#
# Error Twilio 63031: From y To no pueden ser el mismo número. El From es siempre el de Twilio
# (sandbox +14155238886 o tu WA Business); el To es el cliente.
#
# QUIÉN ENVÍA (número de Twilio/WhatsApp Business):
#   Sandbox: suele ser whatsapp:+14155238886 (el que te da Twilio).
#   Producción: tu número de WhatsApp Business aprobado (ej. whatsapp:+34XXXXXXXXX).
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
#
# QUIÉN RECIBE (tu móvil / admin): el que tú pusiste en tu lista.
WHATSAPP_CONTROL_NUMBER=+34614392011
SUPERUSER_PHONE=+34614392011
ZEUS_ADMIN_PHONE=+34614392011
#
WHATSAPP_SANDBOX_MODE=false
